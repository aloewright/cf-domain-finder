{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "nomenclature",
  "main": "src/index.ts",
  "compatibility_date": "2026-05-16",
  "workers_dev": true,
  "routes": [
    {
      "pattern": "blabout.com/*",
      "zone_name": "blabout.com"
    }
  ],
  "observability": {
    "enabled": true
  },
  "ai": {
    "binding": "AI"
  }
}
